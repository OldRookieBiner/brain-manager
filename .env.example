# OpenClaw Brain Manager 配置示例

# ===========================================
# 多语言配置（新增）
# ===========================================
# 默认输出语言（zh=中文，en=English，ja=日本語，ko=한국어）
# 也可以在调用工具时通过 --lang 参数指定
DEFAULT_LANGUAGE=zh

# ===========================================
# 思源笔记配置
# ===========================================
# 思源笔记 API 地址
SIYUAN_API_URL=http://127.0.0.1:6806

# 思源笔记 API Token（在思源笔记设置 → 关于 → API Token 获取）
SIYUAN_API_TOKEN=your_siYuan_api_token_here

# 专用笔记本名称（可写）- 每个 OpenClaw 实例应该有独立的笔记本
SIYUAN_NOTEBOOK_NAME=OpenClaw 知识库 - 服务器 A

# 只读笔记本列表（可选，逗号分隔）- 可以读取这些笔记本的知识，但不能写入
SIYUAN_READ_ONLY_NOTEBOOKS=项目管理，技术文档，团队知识库

# ===========================================
# OpenClaw API 配置
# ===========================================
# 通常这些会自动从 OpenClaw 环境获取，无需手动设置
# OPENCLAW_API_KEY=your_openclaw_api_key
# OPENCLAW_API_ENDPOINT=https://api.openclaw.ai/v1

# ===========================================
# 本地存储配置
# ===========================================
# 本地存储路径（相对于 OpenClaw 工作目录）
KNOWLEDGE_STORAGE_PATH=./docs/knowledge-base

# 是否启用自动标签
KNOWLEDGE_AUTO_TAG=true

# 检索默认返回数量
KNOWLEDGE_SEARCH_LIMIT=5

# ===========================================
# 智能检测配置（可选）
# ===========================================
# 自动更新阈值（相似度 > 80% 自动更新）
# SMART_DETECTION_AUTO_UPDATE_THRESHOLD=0.8

# 询问用户阈值（相似度 50-80% 询问用户）
# SMART_DETECTION_ASK_USER_THRESHOLD=0.5
